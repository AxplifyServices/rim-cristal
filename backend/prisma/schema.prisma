generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addresses {
  id         Int      @id @default(autoincrement())
  user_id    Int
  label      String?  @db.VarChar(120)
  first_name String   @db.VarChar(120)
  last_name  String   @db.VarChar(120)
  address    String
  apt        String?  @db.VarChar(120)
  city       String   @db.VarChar(120)
  state      String?  @db.VarChar(120)
  zip        String   @db.VarChar(50)
  country    String   @default("Morocco") @db.VarChar(120)
  phone      String?  @db.VarChar(50)
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model contact_messages {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(160)
  email      String   @db.VarChar(255)
  subject    String   @db.VarChar(255)
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coupons {
  id               Int       @id @default(autoincrement())
  code             String    @unique @db.VarChar(80)
  description      String?
  discount_type    String    @default("percent") @db.VarChar(20)
  discount_value   Decimal   @db.Decimal(12, 2)
  min_order_amount Decimal   @default(0) @db.Decimal(12, 2)
  max_uses         Int?
  uses_count       Int       @default(0)
  valid_from       DateTime? @db.Timestamp(6)
  valid_until      DateTime? @db.Timestamp(6)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
}

model newsletter_subscribers {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(255)
  first_name      String?   @db.VarChar(120)
  is_active       Boolean   @default(true)
  subscribed_at   DateTime  @default(now()) @db.Timestamp(6)
  unsubscribed_at DateTime? @db.Timestamp(6)
}

model order_items {
  id                Int       @id @default(autoincrement())
  order_id          Int
  product_id        Int?
  product_name      String    @db.VarChar(255)
  product_reference String?   @db.VarChar(100)
  product_image     String?
  selected_color    String?   @db.VarChar(80)
  selected_size     String?   @db.VarChar(80)
  unit_price        Decimal   @db.Decimal(12, 2)
  quantity          Int       @default(1)
  line_total        Decimal   @db.Decimal(12, 2)
  orders            orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products          products? @relation(fields: [product_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id                  Int             @id @default(autoincrement())
  order_number        String          @unique @db.VarChar(80)
  user_id             Int?
  subtotal            Decimal         @db.Decimal(12, 2)
  shipping_cost       Decimal         @default(0) @db.Decimal(12, 2)
  discount_amount     Decimal         @default(0) @db.Decimal(12, 2)
  coupon_code         String?         @db.VarChar(80)
  total               Decimal         @db.Decimal(12, 2)
  status              String          @default("pending") @db.VarChar(40)
  payment_status      String          @default("pending") @db.VarChar(40)
  payment_method      String?         @db.VarChar(80)
  shipping_first_name String          @db.VarChar(120)
  shipping_last_name  String          @db.VarChar(120)
  shipping_email      String          @db.VarChar(255)
  shipping_phone      String?         @db.VarChar(50)
  shipping_address    String
  shipping_apt        String?         @db.VarChar(120)
  shipping_city       String          @db.VarChar(120)
  shipping_state      String?         @db.VarChar(120)
  shipping_zip        String          @db.VarChar(50)
  shipping_country    String          @default("Morocco") @db.VarChar(120)
  notes               String?
  created_at          DateTime        @default(now()) @db.Timestamp(6)
  updated_at          DateTime        @default(now()) @db.Timestamp(6)
  point_of_sale_id    Int?
  order_items         order_items[]
  point_of_sales      point_of_sales? @relation(fields: [point_of_sale_id], references: [id], onUpdate: NoAction)
  users               users?          @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([order_number], map: "idx_orders_order_number")
  @@index([user_id], map: "idx_orders_user_id")
  @@index([point_of_sale_id], map: "idx_orders_point_of_sale")
}

model products {
  id                                                             Int                        @id @default(autoincrement())
  name                                                           String                     @db.VarChar(255)
  slug                                                           String                     @unique @db.VarChar(255)
  reference                                                      String                     @unique @db.VarChar(100)
  marque                                                         String?                    @db.VarChar(120)
  rubrique                                                       String?                    @db.VarChar(120)
  categorie                                                      String?                    @db.VarChar(120)
  famille                                                        String?                    @db.VarChar(120)
  description                                                    String?
  features                                                       Json                       @default("[]")
  specs                                                          Json                       @default("{}")
  url_image1                                                     String?
  url_image2                                                     String?
  url_image3                                                     String?
  url_image4                                                     String?
  url_image5                                                     String?
  price                                                          Decimal                    @db.Decimal(12, 2)
  sale_price                                                     Decimal?                   @db.Decimal(12, 2)
  discount_percent                                               Int                        @default(0)
  colors                                                         Json                       @default("[]")
  sizes                                                          Json                       @default("[]")
  stock                                                          Int                        @default(0)
  weight                                                         Decimal?                   @db.Decimal(12, 2)
  badge                                                          String?                    @db.VarChar(100)
  is_active                                                      Boolean                    @default(true)
  is_featured                                                    Boolean                    @default(false)
  is_new                                                         Boolean                    @default(false)
  is_bestseller                                                  Boolean                    @default(false)
  rating                                                         Decimal                    @default(0) @db.Decimal(3, 2)
  reviews_count                                                  Int                        @default(0)
  created_at                                                     DateTime                   @default(now()) @db.Timestamp(6)
  updated_at                                                     DateTime                   @default(now()) @db.Timestamp(6)
  category_id                                                    Int?
  subcategory_id                                                 Int?
  room_tags                                                      Json                       @default("[]")
  material_tags                                                  Json                       @default("[]")
  style_tags                                                     Json                       @default("[]")
  dimensions                                                     Json                       @default("{}")
  care_instructions                                              String?
  origin_country                                                 String?                    @db.VarChar(120)
  collection_name                                                String?                    @db.VarChar(160)
  seo_title                                                      String?                    @db.VarChar(255)
  seo_description                                                String?
  price_wholesale                                                Decimal                    @default(0) @db.Decimal(12, 2)
  wholesale_min_qty                                              Int                        @default(1)
  order_items                                                    order_items[]
  point_of_sale_sale_items                                       point_of_sale_sale_items[]
  point_of_sale_stocks                                           point_of_sale_stocks[]
  product_categories_products_category_idToproduct_categories    product_categories?        @relation("products_category_idToproduct_categories", fields: [category_id], references: [id], onUpdate: NoAction)
  product_categories_products_subcategory_idToproduct_categories product_categories?        @relation("products_subcategory_idToproduct_categories", fields: [subcategory_id], references: [id], onUpdate: NoAction)
  reviews                                                        reviews[]
  stock_movements                                                stock_movements[]
  wishlist_items                                                 wishlist_items[]

  @@index([is_active], map: "idx_products_active")
  @@index([categorie], map: "idx_products_categorie")
  @@index([is_featured], map: "idx_products_featured")
  @@index([slug], map: "idx_products_slug")
  @@index([category_id], map: "idx_products_category_id")
  @@index([material_tags], map: "idx_products_material_tags", type: Gin)
  @@index([room_tags], map: "idx_products_room_tags", type: Gin)
  @@index([style_tags], map: "idx_products_style_tags", type: Gin)
  @@index([subcategory_id], map: "idx_products_subcategory_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id          Int      @id @default(autoincrement())
  product_id  Int
  user_id     Int?
  guest_name  String?  @db.VarChar(160)
  guest_email String?  @db.VarChar(255)
  rating      Int
  title       String?  @db.VarChar(255)
  body        String?
  is_verified Boolean  @default(false)
  is_approved Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  products    products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([product_id], map: "idx_reviews_product_id")
}

model users {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  hashed_password String
  first_name      String           @db.VarChar(120)
  last_name       String           @db.VarChar(120)
  phone           String?          @db.VarChar(50)
  is_active       Boolean          @default(true)
  is_admin        Boolean          @default(false)
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @db.Timestamp(6)
  addresses       addresses[]
  orders          orders[]
  reviews         reviews[]
  wishlist_items  wishlist_items[]
}

model wishlist_items {
  id         Int      @id @default(autoincrement())
  user_id    Int
  product_id Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, product_id], map: "uq_wishlist_user_product")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model point_of_sale_sale_items {
  id                  Int                 @id @default(autoincrement())
  sale_id             Int
  product_id          Int?
  product_name        String              @db.VarChar(255)
  product_reference   String?             @db.VarChar(100)
  unit_price          Decimal             @default(0) @db.Decimal(12, 2)
  quantity            Int                 @default(1)
  line_total          Decimal             @default(0) @db.Decimal(12, 2)
  products            products?           @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  point_of_sale_sales point_of_sale_sales @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_pos_sale_items_product")
  @@index([sale_id], map: "idx_pos_sale_items_sale")
}

model point_of_sale_sales {
  id                       Int                        @id @default(autoincrement())
  point_of_sale_id         Int
  sale_number              String                     @unique @db.VarChar(80)
  subtotal                 Decimal                    @default(0) @db.Decimal(12, 2)
  discount_amount          Decimal                    @default(0) @db.Decimal(12, 2)
  total                    Decimal                    @default(0) @db.Decimal(12, 2)
  customer_name            String?                    @db.VarChar(160)
  customer_phone           String?                    @db.VarChar(50)
  note                     String?
  created_at               DateTime                   @default(now()) @db.Timestamp(6)
  point_of_sale_sale_items point_of_sale_sale_items[]
  point_of_sales           point_of_sales             @relation(fields: [point_of_sale_id], references: [id], onUpdate: NoAction)
  stock_movements          stock_movements[]

  @@index([created_at], map: "idx_pos_sales_created_at")
  @@index([point_of_sale_id], map: "idx_pos_sales_pos")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model point_of_sale_stocks {
  id               Int            @id @default(autoincrement())
  point_of_sale_id Int
  product_id       Int
  quantity         Int            @default(0)
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime       @default(now()) @db.Timestamp(6)
  point_of_sales   point_of_sales @relation(fields: [point_of_sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products       @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([point_of_sale_id, product_id], map: "uq_pos_product_stock")
  @@index([point_of_sale_id], map: "idx_pos_stocks_pos")
  @@index([product_id], map: "idx_pos_stocks_product")
}

model point_of_sales {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @db.VarChar(160)
  address              String?
  city                 String?                @db.VarChar(120)
  phone                String?                @db.VarChar(50)
  manager_name         String?                @db.VarChar(160)
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  updated_at           DateTime               @default(now()) @db.Timestamp(6)
  orders               orders[]
  point_of_sale_sales  point_of_sale_sales[]
  point_of_sale_stocks point_of_sale_stocks[]
  stock_movements      stock_movements[]

  @@index([is_active], map: "idx_point_of_sales_active")
  @@index([city], map: "idx_point_of_sales_city")
}

model product_categories {
  id                                                   Int                  @id @default(autoincrement())
  parent_id                                            Int?
  name_fr                                              String               @db.VarChar(160)
  name_en                                              String?              @db.VarChar(160)
  slug                                                 String               @unique @db.VarChar(180)
  level                                                Int                  @default(1)
  sort_order                                           Int                  @default(0)
  is_active                                            Boolean              @default(true)
  created_at                                           DateTime             @default(now()) @db.Timestamp(6)
  updated_at                                           DateTime             @default(now()) @db.Timestamp(6)
  product_categories                                   product_categories?  @relation("product_categoriesToproduct_categories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_product_categories                             product_categories[] @relation("product_categoriesToproduct_categories")
  products_products_category_idToproduct_categories    products[]           @relation("products_category_idToproduct_categories")
  products_products_subcategory_idToproduct_categories products[]           @relation("products_subcategory_idToproduct_categories")

  @@index([is_active], map: "idx_product_categories_active")
  @@index([parent_id], map: "idx_product_categories_parent_id")
  @@index([slug], map: "idx_product_categories_slug")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock_movements {
  id                  Int                  @id @default(autoincrement())
  product_id          Int
  point_of_sale_id    Int?
  movement_type       String               @db.VarChar(40)
  quantity            Int
  stock_global_before Int?
  stock_global_after  Int?
  stock_pos_before    Int?
  stock_pos_after     Int?
  sale_id             Int?
  note                String?
  created_at          DateTime             @default(now()) @db.Timestamp(6)
  point_of_sales      point_of_sales?      @relation(fields: [point_of_sale_id], references: [id], onUpdate: NoAction)
  products            products             @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  point_of_sale_sales point_of_sale_sales? @relation(fields: [sale_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_stock_movements_created_at")
  @@index([point_of_sale_id], map: "idx_stock_movements_pos")
  @@index([product_id], map: "idx_stock_movements_product")
  @@index([movement_type], map: "idx_stock_movements_type")
}
