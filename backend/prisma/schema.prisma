/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model homepage_brochures {
  id                 Int      @id @default(autoincrement())
  image_url          String
  mobile_image_url   String?
  alt_text_fr        String   @db.VarChar(255)
  alt_text_en        String?  @db.VarChar(255)
  link_url           String?
  link_target        String   @default("_self") @db.VarChar(20)
  sort_order         Int      @default(0)
  is_active          Boolean  @default(true)
  desktop_fit        String   @default("cover") @db.VarChar(20)
  desktop_position_x Decimal  @default(50) @db.Decimal(6, 2)
  desktop_position_y Decimal  @default(50) @db.Decimal(6, 2)
  desktop_zoom       Decimal  @default(1) @db.Decimal(6, 3)
  mobile_fit         String   @default("cover") @db.VarChar(20)
  mobile_position_x  Decimal  @default(50) @db.Decimal(6, 2)
  mobile_position_y  Decimal  @default(50) @db.Decimal(6, 2)
  mobile_zoom        Decimal  @default(1) @db.Decimal(6, 3)
  created_by_user_id Int?
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @default(now()) @db.Timestamp(6)
  users              users?   @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction, map: "fk_homepage_brochures_created_by_user")

  @@index([is_active, sort_order, id], map: "idx_homepage_brochures_public")
  @@index([sort_order, id], map: "idx_homepage_brochures_sort_order")
}
